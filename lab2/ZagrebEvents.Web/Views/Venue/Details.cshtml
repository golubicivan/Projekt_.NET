@model Venue
@{
    ViewData["Title"] = Model.Name;
    var upcomingEvents = Model.Events.Where(e => e.IsUpcoming).OrderBy(e => e.StartTime).ToList();
    var pastEvents = Model.Events.Where(e => !e.IsUpcoming).OrderByDescending(e => e.StartTime).ToList();
}

@section Breadcrumbs {
<nav class="ze-breadcrumb">
    <a href="/">Karta</a> › <a href="/Venue/Index">Lokacije</a> › <span>@Model.Name</span>
</nav>
}

<div class="venue-detail">
    <div class="venue-hero">
        <img src="@Model.ImageUrl" alt="@Model.Name"
             onerror="this.src='https://images.unsplash.com/photo-1566737236500-c8ac43014a67?w=1200'" />
        <div class="venue-hero-overlay">
            <span class="venue-type-badge-lg">@Model.Type</span>
            <h1>@Model.Name</h1>
            <p>📍 @Model.Address</p>
        </div>
    </div>

    <div class="venue-detail-grid">
        <div class="venue-main">
            <div class="detail-section">
                <h2>O lokaciji</h2>
                <p>@Model.Description</p>
            </div>

            <div class="detail-section event-info-grid" style="display:grid;grid-template-columns:repeat(3,1fr);gap:12px">
                <div class="ze-stat-card"><div class="stat-label">Kapacitet</div><div class="stat-value">@Model.Capacity</div></div>
                <div class="ze-stat-card"><div class="stat-label">Radno vrijeme</div><div class="stat-value" style="font-size:1rem">@Model.WorkingHours</div></div>
                <div class="ze-stat-card"><div class="stat-label">Kontakt</div><div class="stat-value" style="font-size:0.9rem">@Model.ContactPhone</div></div>
            </div>

            <div class="detail-section">
                <h2>Nadolazeći eventi (@upcomingEvents.Count)</h2>
                @if (upcomingEvents.Any())
                {
                    <div style="display:flex;flex-direction:column;gap:10px">
                        @foreach (var ev in upcomingEvents)
                        {
                            <a href="/Event/Details/@ev.Id" class="venue-event-row">
                                <span class="event-badge" style="background:@ev.TypeColor;position:static;font-size:0.7rem">@ev.TypeIcon @ev.TypeLabel</span>
                                <span class="venue-event-name">@ev.Name</span>
                                <span class="text-muted-ze">@ev.StartTime.ToString("dd.MM. HH:mm")</span>
                                <span style="color:#10b981;font-weight:600">@(ev.EntryPrice == 0 ? "Besplatno" : $"{ev.EntryPrice:F0}€")</span>
                            </a>
                        }
                    </div>
                }
                else { <p class="text-muted-ze">Nema nadolazećih evenata.</p> }
            </div>

            @if (pastEvents.Any())
            {
                <div class="detail-section">
                    <h2>Prošli eventi</h2>
                    <div style="display:flex;flex-direction:column;gap:10px">
                        @foreach (var ev in pastEvents)
                        {
                            <a href="/Event/Details/@ev.Id" class="venue-event-row" style="opacity:0.6">
                                <span class="event-badge" style="background:@ev.TypeColor;position:static;font-size:0.7rem">@ev.TypeIcon @ev.TypeLabel</span>
                                <span class="venue-event-name">@ev.Name</span>
                                <span class="text-muted-ze">@ev.StartTime.ToString("dd.MM.yyyy")</span>
                            </a>
                        }
                    </div>
                </div>
            }
        </div>

        <div class="venue-sidebar">
            <div class="detail-section">
                <h3>Stolovi</h3>
                @foreach (var table in Model.Tables)
                {
                    <div class="table-card" style="margin-bottom:8px;text-align:left;display:flex;justify-content:space-between;align-items:center">
                        <span style="font-weight:600">Stol @table.TableNumber</span>
                        <span class="@(table.Zone == TableZone.VIP ? "zone-vip" : "zone-regular")">@table.Zone</span>
                        <span class="text-muted-ze">@table.SeatCount 👥</span>
                    </div>
                }
            </div>

            <div class="detail-section">
                <h3>Cjenik</h3>
                <table class="ze-table" style="font-size:0.82rem">
                    <thead><tr><th>Artikl</th><th>Cijena</th></tr></thead>
                    <tbody>
                        @foreach (var item in Model.PriceList)
                        {
                            <tr>
                                <td>@item.ItemName<br/><small class="text-muted-ze">@item.Category</small></td>
                                <td style="color:#10b981;font-weight:600">@item.Price.ToString("F2") €</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<style>
.venue-hero { position: relative; height: 380px; border-radius: 20px; overflow: hidden; margin-bottom: 32px; }
.venue-hero img { width: 100%; height: 100%; object-fit: cover; }
.venue-hero-overlay { position: absolute; inset: 0; background: linear-gradient(to top, rgba(10,10,15,0.95) 0%, transparent 60%); display: flex; flex-direction: column; justify-content: flex-end; padding: 28px 32px; }
.venue-hero-overlay h1 { font-size: 2rem; font-weight: 700; color: #f1f5f9; margin: 8px 0 4px; }
.venue-hero-overlay p { color: #94a3b8; margin: 0; }
.venue-type-badge-lg { display: inline-block; padding: 4px 12px; border-radius: 20px; background: rgba(6,182,212,0.8); color: #fff; font-size: 0.75rem; font-weight: 600; text-transform: uppercase; }
.venue-detail-grid { display: grid; grid-template-columns: 1fr 300px; gap: 32px; align-items: start; }
.venue-event-row { display: flex; align-items: center; gap: 12px; padding: 10px 14px; background: #12121a; border-radius: 10px; text-decoration: none; color: inherit; border: 1px solid rgba(255,255,255,0.05); transition: border-color 0.2s; }
.venue-event-row:hover { border-color: rgba(124,58,237,0.4); }
.venue-event-name { flex: 1; font-size: 0.9rem; font-weight: 500; color: #f1f5f9; }
.zone-vip { display: inline-block; padding: 2px 8px; border-radius: 10px; background: rgba(124,58,237,0.2); color: #7c3aed; font-size: 0.7rem; font-weight: 600; }
.zone-regular { display: inline-block; padding: 2px 8px; border-radius: 10px; background: rgba(6,182,212,0.15); color: #06b6d4; font-size: 0.7rem; font-weight: 600; }
.table-card { background: #12121a; border: 1px solid rgba(255,255,255,0.06); border-radius: 8px; padding: 10px 12px; }
@@media (max-width: 768px) { .venue-detail-grid { grid-template-columns: 1fr; } .venue-hero { height: 240px; } }
</style>
