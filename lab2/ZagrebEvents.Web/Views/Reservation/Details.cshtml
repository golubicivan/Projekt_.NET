@model Reservation
@{
    ViewData["Title"] = $"Rezervacija #{Model.Id}";
}

@section Breadcrumbs {
<nav class="ze-breadcrumb">
    <a href="/">Karta</a> › <a href="/Reservation/Index">Rezervacije</a> › <span>Rezervacija #@Model.Id</span>
</nav>
}

<div class="ze-page-header">
    <h1>Rezervacija #@Model.Id</h1>
    <span style="color:@Model.StatusColor;font-size:1.1rem;font-weight:600">@Model.StatusLabel</span>
</div>

<div style="display:grid;grid-template-columns:1fr 1fr;gap:24px;margin-top:24px">
    <div class="detail-section">
        <h2>Detalji rezervacije</h2>
        <table class="ze-table">
            <tbody>
                <tr><td class="text-muted-ze">Korisnik</td><td><a href="/User/Details/@Model.User.Id" style="color:#7c3aed">@Model.User.FullName</a></td></tr>
                <tr><td class="text-muted-ze">Event</td><td><a href="/Event/Details/@Model.Event.Id" style="color:#7c3aed">@Model.Event.Name</a></td></tr>
                <tr><td class="text-muted-ze">Lokacija</td><td>@Model.Event.Venue.Name</td></tr>
                <tr><td class="text-muted-ze">Datum eventa</td><td>@Model.Event.StartTime.ToString("dd.MM.yyyy HH:mm")</td></tr>
                <tr><td class="text-muted-ze">Stol</td><td>Stol @Model.Table?.TableNumber (@Model.Table?.Zone, @Model.Table?.SeatCount mjesta)</td></tr>
                <tr><td class="text-muted-ze">Broj gostiju</td><td>@Model.NumberOfGuests 👥</td></tr>
                <tr><td class="text-muted-ze">Min. potrošnja</td><td style="color:#10b981;font-weight:600">@(Model.MinimumSpending == 0 ? "Nema" : $"{Model.MinimumSpending:F2} EUR")</td></tr>
                <tr><td class="text-muted-ze">Napomena</td><td>@(string.IsNullOrEmpty(Model.Note) ? "—" : Model.Note)</td></tr>
                <tr><td class="text-muted-ze">Kreirano</td><td>@Model.CreatedAt.ToString("dd.MM.yyyy")</td></tr>
                <tr><td class="text-muted-ze">Status</td><td style="color:@Model.StatusColor;font-weight:600">@Model.StatusLabel</td></tr>
            </tbody>
        </table>
    </div>

    <div class="detail-section">
        <h2>Event info</h2>
        <a href="/Event/Details/@Model.Event.Id" style="text-decoration:none">
            <div class="event-card" style="cursor:pointer">
                <div class="event-card-poster">
                    <img src="@Model.Event.PosterUrl" alt="@Model.Event.Name"
                         onerror="this.src='https://images.unsplash.com/photo-1470229722913-7c0e2dbbafd3?w=600'" />
                    <span class="event-badge" style="background:@Model.Event.TypeColor;position:absolute;top:10px;left:10px">
                        @Model.Event.TypeIcon @Model.Event.TypeLabel
                    </span>
                </div>
                <div class="event-card-body">
                    <h3 class="event-card-title">@Model.Event.Name</h3>
                    <div class="event-card-venue">📍 @Model.Event.Venue.Name</div>
                    <div class="event-card-meta">
                        <span>📅 @Model.Event.StartTime.ToString("dd.MM.yyyy HH:mm")</span>
                        <span class="event-card-price">@(Model.Event.EntryPrice == 0 ? "Besplatno" : $"{Model.Event.EntryPrice:F0}€")</span>
                    </div>
                </div>
            </div>
        </a>
    </div>
</div>

<style>
.event-card { background: #1a1a2e; border-radius: 16px; border: 1px solid rgba(124,58,237,0.2); overflow: hidden; }
.event-card-poster { position: relative; aspect-ratio: 16/9; overflow: hidden; }
.event-card-poster img { width: 100%; height: 100%; object-fit: cover; }
.event-card-body { padding: 16px; }
.event-card-title { font-size: 1.05rem; font-weight: 600; color: #f1f5f9; margin: 0 0 8px; }
.event-card-venue { font-size: 0.82rem; color: #94a3b8; margin-bottom: 10px; }
.event-card-meta { display: flex; justify-content: space-between; font-size: 0.8rem; color: #64748b; }
.event-card-price { color: #10b981; font-weight: 600; }
@@media (max-width: 768px) { div[style*="grid-template-columns:1fr 1fr"] { grid-template-columns: 1fr !important; } }
</style>
